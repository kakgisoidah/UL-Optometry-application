<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
              xmlns:vm="clr-namespace:UL_Optometry.ViewModels.Supervisor"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="UL_Optometry.Views.Supervisor.Profile.SupProfilePage"
                 Shell.NavBarIsVisible="False"
             x:DataType="vm:SupProfileViewModel"
             Style="{StaticResource PageStyle}"
             Title="{Binding Title}">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding LoadCommand}"/>
    </ContentPage.Behaviors>

    <ScrollView Style="{StaticResource ScrollStyle}">
        <VerticalStackLayout Spacing="16">

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}"/>
            <Border Style="{StaticResource AlertDangerStyle}" IsVisible="{Binding HasError}">
                <Label Text="{Binding ErrorMessage}" Style="{StaticResource BodyStyle}"
                       TextColor="{StaticResource DangerDark}"/>
            </Border>

            <!-- Avatar + Name -->
            <Border Style="{StaticResource CardStyle}" IsVisible="{Binding IsBusy, Converter={StaticResource InvertBool}}">
                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Border Style="{StaticResource AvatarLargeStyle}" HorizontalOptions="Center">
                        <Label Text="{Binding UserProfile.Initials}"
                               Style="{StaticResource AvatarInitialsStyle}"
                               FontSize="26"/>
                    </Border>
                    <Label Text="{Binding UserProfile.FullName}"
                           FontFamily="DMSansBold" FontSize="18"
                           HorizontalOptions="Center"/>
                    <!-- OP number badge -->
                    <Border Style="{StaticResource BadgeInfoStyle}" HorizontalOptions="Center">
                        <Label Text="{Binding UserProfile.Email}"
                               Style="{StaticResource CaptionStyle}"
                               TextColor="{StaticResource InfoDark}"/>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Success banner -->
            <Border Style="{StaticResource AlertSuccessStyle}" IsVisible="{Binding Saved}">
                <Label Text="✓ Profile updated successfully!"
                       Style="{StaticResource BodyStyle}"
                       TextColor="{StaticResource SuccessDark}"/>
            </Border>

            <!-- Edit profile -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Edit Profile" Style="{StaticResource SubtitleStyle}"/>
                    <Label Text="Full Name" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry Text="{Binding FullName}" Placeholder="Full name"
                               Style="{StaticResource EntryStyle}"/>
                    </Border>
                    <Label Text="Phone Number" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry Text="{Binding Phone}" Placeholder="Phone number"
                               Keyboard="Telephone" Style="{StaticResource EntryStyle}"/>
                    </Border>
                    <Button Text="Save Changes"
                            Command="{Binding SaveProfileCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </VerticalStackLayout>
            </Border>

            <!-- Password change -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Change Password" Style="{StaticResource SubtitleStyle}"/>

                    <Border Style="{StaticResource AlertSuccessStyle}"
                            IsVisible="{Binding PasswordChanged}">
                        <Label Text="✓ Password changed successfully!"
                               Style="{StaticResource BodyStyle}"
                               TextColor="{StaticResource SuccessDark}"/>
                    </Border>

                    <Label Text="New Password (min 8 characters)"
                           Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry Text="{Binding NewPassword}" Placeholder="New password"
                               IsPassword="True" Style="{StaticResource EntryStyle}"/>
                    </Border>

                    <Label Text="Confirm Password" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry Text="{Binding ConfirmPassword}" Placeholder="Confirm password"
                               IsPassword="True" Style="{StaticResource EntryStyle}"/>
                    </Border>

                    <Button Text="Change Password"
                            Command="{Binding ChangePasswordCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            Style="{StaticResource OutlineButtonStyle}"/>
                </VerticalStackLayout>
            </Border>

            <!-- Logout -->
            <Button Text="Log Out"
                    Command="{Binding LogoutCommand}"
                    Style="{StaticResource DangerButtonStyle}"
                    Margin="0,8,0,32"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>