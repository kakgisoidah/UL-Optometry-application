<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:UL_Optometry.ViewModels.Supervisor"
             xmlns:models="clr-namespace:UL_Optometry.Models.Notification"
             
             x:Class="UL_Optometry.Views.Supervisor.Notification.SupNotificationsPage"
                 Shell.NavBarIsVisible="False"
              x:DataType="vm:SupNotificationsViewModel"
             Style="{StaticResource PageStyle}" Title="Notifications">
    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding LoadCommand}"/>
    </ContentPage.Behaviors>
    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" BackgroundColor="{StaticResource Card}" Padding="16">
            <Label Grid.Column="0" Text="Notifications" Style="{StaticResource TitleStyle}"/>
            <Button Grid.Column="1" Text="Mark all read" Command="{Binding MarkAllReadCommand}" Style="{StaticResource SmallButtonStyle}" IsVisible="{Binding UnreadCount, Converter={StaticResource IntToBool}}"/>
        </Grid>
        <CollectionView Grid.Row="1" ItemsSource="{Binding Notifications}" SelectionMode="None" EmptyView="No notifications yet.">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:AppNotification">
                    <Grid ColumnDefinitions="16,*" Padding="16,14" ColumnSpacing="10">
                        <Ellipse Grid.Column="0" WidthRequest="8" HeightRequest="8" Fill="{StaticResource Accent}" VerticalOptions="Start" Margin="0,4,0,0" IsVisible="{Binding IsRead, Converter={StaticResource InvertBool}}"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="3">
                            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}"/>
                            <Border Style="{StaticResource AlertDangerStyle}" IsVisible="{Binding HasError}">
                                <Label Text="{Binding ErrorMessage}" Style="{StaticResource BodyStyle}"
                       TextColor="{StaticResource DangerDark}"/>
                            </Border>
                            <Label Text="{Binding Title}" FontFamily="DMSansMedium" FontSize="14"/>
                            <Label Text="{Binding Message}" Style="{StaticResource MutedLabelStyle}" LineBreakMode="WordWrap"/>
                            <Label Text="{Binding TimeAgo}" Style="{StaticResource CaptionStyle}" Margin="0,4,0,0"/>
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>