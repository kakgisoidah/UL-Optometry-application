<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:UL_Optometry.ViewModels.Admin"
             
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="UL_Optometry.Views.Admin.Settings.SettingsPage"
                 Shell.NavBarIsVisible="False"
             x:DataType="vm:SettingsViewModel"
             Style="{StaticResource PageStyle}"
             Title="{Binding Title}">
    <ScrollView Style="{StaticResource ScrollStyle}">
        <VerticalStackLayout Spacing="16">
            <Border Style="{StaticResource AlertSuccessStyle}" IsVisible="{Binding Saved}">
                <Label Text="Settings saved." Style="{StaticResource BodyStyle}" TextColor="{StaticResource SuccessDark}"/>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="General Settings" FontFamily="DMSansSemiBold" FontSize="14"/>
                    <Label Text="System Name" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry Text="{Binding SystemName}" Style="{StaticResource EntryStyle}"/>
                    </Border>
                    <Label Text="Institution" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry Text="{Binding Institution}" Style="{StaticResource EntryStyle}"/>
                    </Border>
                    <Label Text="Contact Email" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry Text="{Binding ContactEmail}" Keyboard="Email" Style="{StaticResource EntryStyle}"/>
                    </Border>
                    <Button Text="Save General" Command="{Binding SaveGeneralCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </VerticalStackLayout>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="PoE Configuration" FontFamily="DMSansSemiBold" FontSize="14"/>
                    <Label Text="{Binding TotalPoeHours, StringFormat='Total: {0} hours (target = 500)'}"
                           FontFamily="DMSansMedium" FontSize="13" TextColor="{StaticResource Primary}"/>
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10">
                        <Label Grid.Row="0" Grid.Column="0" Text="Binocular Vision" Style="{StaticResource FormLabelStyle}" VerticalOptions="Center"/>
                        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource InputBorderStyle}" WidthRequest="80">
                            <Entry Text="{Binding BinVisionHrs}" Keyboard="Numeric" Style="{StaticResource EntryStyle}"/>
                        </Border>
                        <Label Grid.Row="1" Grid.Column="0" Text="Paediatric" Style="{StaticResource FormLabelStyle}" VerticalOptions="Center"/>
                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource InputBorderStyle}" WidthRequest="80">
                            <Entry Text="{Binding PaediatricHrs}" Keyboard="Numeric" Style="{StaticResource EntryStyle}"/>
                        </Border>
                        <Label Grid.Row="2" Grid.Column="0" Text="Contact Lens" Style="{StaticResource FormLabelStyle}" VerticalOptions="Center"/>
                        <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource InputBorderStyle}" WidthRequest="80">
                            <Entry Text="{Binding ContactLensHrs}" Keyboard="Numeric" Style="{StaticResource EntryStyle}"/>
                        </Border>
                        <Label Grid.Row="3" Grid.Column="0" Text="Low Vision" Style="{StaticResource FormLabelStyle}" VerticalOptions="Center"/>
                        <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource InputBorderStyle}" WidthRequest="80">
                            <Entry Text="{Binding LowVisionHrs}" Keyboard="Numeric" Style="{StaticResource EntryStyle}"/>
                        </Border>
                        <Label Grid.Row="4" Grid.Column="0" Text="Ocular Disease" Style="{StaticResource FormLabelStyle}" VerticalOptions="Center"/>
                        <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource InputBorderStyle}" WidthRequest="80">
                            <Entry Text="{Binding OcularDiseaseHrs}" Keyboard="Numeric" Style="{StaticResource EntryStyle}"/>
                        </Border>
                    </Grid>
                    <Button Text="Save PoE Settings" Command="{Binding SavePoeCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </VerticalStackLayout>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Quick Links" FontFamily="DMSansSemiBold" FontSize="14"/>
                    <Button Text="Manage Users"  Command="{Binding GoToPageCommand}" CommandParameter="UsersPage"       Style="{StaticResource OutlineButtonStyle}" HorizontalOptions="Fill"/>
                    <Button Text="Audit Log"     Command="{Binding GoToPageCommand}" CommandParameter="AuditPage"       Style="{StaticResource OutlineButtonStyle}" HorizontalOptions="Fill"/>
                    <Button Text="Scheduling"    Command="{Binding GoToPageCommand}" CommandParameter="SchedulingPage"  Style="{StaticResource OutlineButtonStyle}" HorizontalOptions="Fill"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>