<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:UL_Optometry.ViewModels.Admin"
             
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="UL_Optometry.Views.Admin.Reports.ReportsPage"
                 Shell.NavBarIsVisible="False"
             x:DataType="vm:ReportsViewModel"
             Style="{StaticResource PageStyle}"
             Title="{Binding Title}">
    <ScrollView Style="{StaticResource ScrollStyle}">
        <VerticalStackLayout Spacing="16">
            <Label Text="Reports Center" Style="{StaticResource HeadlineStyle}"/>
            <Label Text="Tap a report card to view data or download a PDF." Style="{StaticResource MutedLabelStyle}"/>
            <CollectionView ItemsSource="{Binding Cards}" SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2"
                                     HorizontalItemSpacing="12" VerticalItemSpacing="12"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ReportsViewModel+ReportCard">
                        <Border Style="{StaticResource CardStyle}">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding Icon}" FontSize="28" HorizontalOptions="Center"/>
                                <Label Text="{Binding Title}" FontFamily="DMSansSemiBold" FontSize="13"
                                       HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                                <Label Text="{Binding Description}" Style="{StaticResource CaptionStyle}"
                                       HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                    <Button Grid.Column="0" Text="View"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ReportsViewModel}}, Path=NavigateToReportCommand}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource OutlineButtonStyle}"
                                            HeightRequest="36" FontSize="12"/>
                                    <Button Grid.Column="1" Text="PDF"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ReportsViewModel}}, Path=DownloadPdfCommand}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource OutlineButtonStyle}"
                                            WidthRequest="52" HeightRequest="36" FontSize="11"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>