<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:UL_Optometry.ViewModels.Admin"
             
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="UL_Optometry.Views.Admin.Users.AddUserPage"
                 Shell.NavBarIsVisible="False"
             x:DataType="vm:AddUserViewModel"
             Style="{StaticResource PageStyle}"
             Title="{Binding Title}">
    
    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding LoadCommand}"/>
    </ContentPage.Behaviors>
    <ScrollView Style="{StaticResource ScrollStyle}">
        <VerticalStackLayout Spacing="16">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource Primary}"/>
            <Border Style="{StaticResource AlertDangerStyle}" IsVisible="{Binding HasError}">
                <Label Text="{Binding ErrorMessage}" Style="{StaticResource BodyStyle}" TextColor="{StaticResource DangerDark}"/>
            </Border>
            <Border Style="{StaticResource AlertSuccessStyle}" IsVisible="{Binding Created}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="User created successfully." Style="{StaticResource BodyStyle}" TextColor="{StaticResource SuccessDark}"/>
                    <Label Text="{Binding GeneratedPassword, StringFormat='Default password: {0}'}"
                           FontFamily="DMSansBold" FontSize="14" TextColor="{StaticResource SuccessDark}"/>
                </VerticalStackLayout>
            </Border>
            <VerticalStackLayout Spacing="12" IsVisible="{Binding Created, Converter={StaticResource InvertBool}}">
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="User Details" FontFamily="DMSansSemiBold" FontSize="14"/>
                        <Label Text="Full Name *" Style="{StaticResource FormLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry Text="{Binding FullName}" Placeholder="Full name" Style="{StaticResource EntryStyle}"/>
                        </Border>
                        <Label Text="Email *" Style="{StaticResource FormLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry Text="{Binding Email}" Placeholder="user@ul.ac.za" Keyboard="Email" Style="{StaticResource EntryStyle}"/>
                        </Border>
                        <Label Text="Phone" Style="{StaticResource FormLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry Text="{Binding Phone}" Placeholder="Phone number" Keyboard="Telephone" Style="{StaticResource EntryStyle}"/>
                        </Border>
                        <Label Text="Role *" Style="{StaticResource FormLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Picker ItemsSource="{Binding RoleOptions}" SelectedItem="{Binding SelectedRole}"
                                    Title="Select role" Style="{StaticResource PickerStyle}"/>
                        </Border>
                    </VerticalStackLayout>
                </Border>
                <Border Style="{StaticResource CardStyle}" IsVisible="{Binding IsSupervisor}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Supervisor Details" FontFamily="DMSansSemiBold" FontSize="14"/>
                        <Label Text="HPCSA / OP Number *" Style="{StaticResource FormLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry Text="{Binding OpNumber}" Placeholder="e.g. OP012345" Style="{StaticResource EntryStyle}"/>
                        </Border>
                        <Label Text="Qualification" Style="{StaticResource FormLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry Text="{Binding Qualification}" Placeholder="e.g. M.Optom" Style="{StaticResource EntryStyle}"/>
                        </Border>
                        <Border Style="{StaticResource AlertInfoStyle}">
                            <Label Text="A supervisor can cover multiple cubicles simultaneously — no upper limit."
                                   Style="{StaticResource BodyStyle}" TextColor="{StaticResource InfoDark}"/>
                        </Border>
                    </VerticalStackLayout>
                </Border>
                <Border Style="{StaticResource CardStyle}" IsVisible="{Binding IsStudent}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Student Details" FontFamily="DMSansSemiBold" FontSize="14"/>
                        <Label Text="Student Number *" Style="{StaticResource FormLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry Text="{Binding StudentNumber}" Placeholder="e.g. 20210045" Style="{StaticResource EntryStyle}"/>
                        </Border>
                        <Label Text="Year of Study" Style="{StaticResource FormLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Picker ItemsSource="{Binding YearOptions}" SelectedItem="{Binding YearOfStudy}"
                                    Style="{StaticResource PickerStyle}"/>
                        </Border>
                    </VerticalStackLayout>
                </Border>
                <Border Style="{StaticResource CardStyle}" BackgroundColor="{StaticResource SuccessLight}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Auto-Generated Default Password" FontFamily="DMSansSemiBold" FontSize="13"
                               TextColor="{StaticResource SuccessDark}"/>
                        <Label Text="{Binding GeneratedPassword}" FontFamily="DMSansBold" FontSize="18"
                               TextColor="{StaticResource SuccessDark}" HorizontalOptions="Center"/>
                        <Button Text="Regenerate" Command="{Binding GeneratePasswordCommand}"
                                Style="{StaticResource SmallButtonStyle}"/>
                        <Border Style="{StaticResource AlertWarningStyle}">
                            <Label Text="User will be forced to change this password on first login."
                                   Style="{StaticResource BodyStyle}" TextColor="{StaticResource WarningDark}"/>
                        </Border>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
            <Button Text="Create User" Command="{Binding CreateUserCommand}"
                    IsEnabled="{Binding IsNotBusy}" Style="{StaticResource PrimaryButtonStyle}"
                    IsVisible="{Binding Created, Converter={StaticResource InvertBool}}"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>