<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:UL_Optometry.ViewModels.Admin"
             xmlns:booking="clr-namespace:UL_Optometry.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="UL_Optometry.Views.Admin.Scheduling.SchedulingPage"
             Shell.NavBarIsVisible="False"
             x:DataType="vm:SchedulingViewModel"
             Style="{StaticResource PageStyle}"
             Title="{Binding Title}">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding LoadCommand}"/>
    </ContentPage.Behaviors>

    <ScrollView Style="{StaticResource ScrollStyle}">
        <VerticalStackLayout Spacing="16">

            <!-- Busy indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}"/>

            <!-- Error banner -->
            <Border Style="{StaticResource AlertDangerStyle}" IsVisible="{Binding HasError}">
                <Label Text="{Binding ErrorMessage}"
                       Style="{StaticResource BodyStyle}"
                       TextColor="{StaticResource DangerDark}"/>
            </Border>

            <!-- PAGE HEADER -->
            <VerticalStackLayout Spacing="2">
                <Label Text="Daily cubicle assignments"
                       Style="{StaticResource TitleStyle}"
                       FontSize="20"/>
                <Label Style="{StaticResource CaptionStyle}">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Assignments for "/>
                            <Span Text="{Binding SessionsCardTitle}"
                                  FontFamily="DMSansSemiBold"/>
                            <Span Text=" — resets each day"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </VerticalStackLayout>

            <!-- SESSION TABS -->
            <Border Style="{StaticResource CardStyle}" Padding="8">
                <CollectionView ItemsSource="{Binding Sessions}"
                                SelectionMode="None"
                                EmptyView="No sessions configured yet.">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="6"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="booking:Session">
                            <Border Style="{Binding Source={RelativeSource AncestorType={x:Type vm:SchedulingViewModel}},
                                            Path=TabBorderStyle}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SchedulingViewModel}},
                                                  Path=SelectSessionCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Label Text="{Binding TabLabel}"
                                       FontSize="13"
                                       FontFamily="DMSansMedium"
                                       Padding="14,9"
                                       TextColor="{Binding Source={RelativeSource AncestorType={x:Type vm:SchedulingViewModel}},
                                                   Path=TabTextColor}"/>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <!-- No session selected hint -->
            <Border Style="{StaticResource AlertInfoStyle}"
                    IsVisible="{Binding CubiclesAreLocked}">
                <Label Text="Select a session above to assign students and supervisors to cubicles."
                       Style="{StaticResource CaptionStyle}"
                       TextColor="{StaticResource InfoDark}"/>
            </Border>

            <!-- TODAY'S APPOINTMENTS -->
            <Label Text="{Binding TodaysBookingsTitle}"
                   Style="{StaticResource TitleStyle}"
                   FontSize="15"/>

            <Border Style="{StaticResource AlertInfoStyle}"
                    IsVisible="{Binding HasTodaysBookings, Converter={StaticResource InvertBool}}">
                <Label Text="No appointments booked for today."
                       Style="{StaticResource CaptionStyle}"
                       TextColor="{StaticResource InfoDark}"/>
            </Border>

            <CollectionView ItemsSource="{Binding TodaysBookings}"
                            SelectionMode="None"
                            IsVisible="{Binding HasTodaysBookings}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="booking:Booking">
                        <Border Style="{StaticResource QueueItemStyle}">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="3">
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding PatientName}"
                                       FontFamily="DMSansSemiBold" FontSize="14"/>
                                <Label Grid.Row="1" Grid.Column="0"
                                       FontFamily="DMSans" FontSize="12"
                                       TextColor="{StaticResource Muted}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding ClinicName}"/>
                                            <Span Text="  ·  "/>
                                            <Span Text="{Binding SessionDisplay}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                        Style="{StaticResource BadgeInfoStyle}"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding StatusDisplay}"
                                           FontFamily="DMSansMedium" FontSize="11"
                                           TextColor="{StaticResource InfoDark}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- CUBICLE CARDS — one card per cubicle, student + supervisor together -->
            <CollectionView ItemsSource="{Binding StudentAssignments}"
                            SelectionMode="None"
                            EmptyView="No cubicles configured. Add cubicles in Settings.">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="2"
                                     HorizontalItemSpacing="12"
                                     VerticalItemSpacing="12"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:StudentAssignmentRow">
                        <Border Style="{StaticResource CardStyle}">
                            <VerticalStackLayout Spacing="12">

                                <!-- Card header: cubicle name + status dot -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           Text="{Binding CubicleName}"
                                           FontFamily="DMSansBold"
                                           FontSize="16"
                                           TextColor="{StaticResource Primary}"
                                           VerticalOptions="Center"/>
                                    <Border Grid.Column="1"
                                            WidthRequest="10"
                                            HeightRequest="10"
                                            VerticalOptions="Center"
                                            Style="{Binding StatusDotStyle}"/>
                                </Grid>

                                <BoxView Style="{StaticResource DividerStyle}" Margin="0"/>

                                <!-- STUDENT ROW -->
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="STUDENT"
                                           FontSize="10"
                                           FontFamily="DMSansSemiBold"
                                           TextColor="{StaticResource TextTertiary}"
                                           CharacterSpacing="1"/>

                                    <!-- Student assigned -->
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="8"
                                          IsVisible="{Binding HasStudent}">
                                        <Border Grid.Column="0" Style="{StaticResource AvatarSmStyle}">
                                            <Label Text="{Binding StudentInitial}"
                                                   Style="{StaticResource AvatarSmLabelStyle}"/>
                                        </Border>
                                        <Label Grid.Column="1"
                                               Text="{Binding StudentName}"
                                               FontSize="13"
                                               VerticalOptions="Center"
                                               LineBreakMode="TailTruncation"/>
                                        <Button Grid.Column="2"
                                                Text="✖"
                                                Style="{StaticResource IconButtonStyle}"
                                                TextColor="{StaticResource Danger}"
                                                VerticalOptions="Center"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SchedulingViewModel}},
                                                          Path=RemoveStudentCommand}"
                                                CommandParameter="{Binding .}"/>
                                    </Grid>

                                    <!-- No student yet -->
                                    <Button Text="+ Assign Student"
                                            Style="{StaticResource OutlineButtonStyle}"
                                            FontSize="12"
                                            Padding="10,7"
                                            HorizontalOptions="Fill"
                                            IsVisible="{Binding HasStudent,
                                                        Converter={StaticResource InvertBool}}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SchedulingViewModel}},
                                                      Path=OpenAssignStudentCommand}"
                                            CommandParameter="{Binding .}"/>
                                </VerticalStackLayout>

                                <BoxView Style="{StaticResource DividerStyle}" Margin="0"/>

                                <!-- SUPERVISOR ROW -->
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="SUPERVISOR"
                                           FontSize="10"
                                           FontFamily="DMSansSemiBold"
                                           TextColor="{StaticResource TextTertiary}"
                                           CharacterSpacing="1"/>

                                    <!-- Supervisor assigned -->
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="8"
                                          IsVisible="{Binding HasSupervisor}">
                                        <Border Grid.Column="0" Style="{StaticResource AvatarSmStyle}">
                                            <Label Text="{Binding SupervisorInitial}"
                                                   Style="{StaticResource AvatarSmLabelStyle}"/>
                                        </Border>
                                        <Label Grid.Column="1"
                                               Text="{Binding SupervisorName}"
                                               FontSize="13"
                                               VerticalOptions="Center"
                                               LineBreakMode="TailTruncation"/>
                                        <Button Grid.Column="2"
                                                Text="✖"
                                                Style="{StaticResource IconButtonStyle}"
                                                TextColor="{StaticResource Danger}"
                                                VerticalOptions="Center"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SchedulingViewModel}},
                                                          Path=RemoveSupervisorCommand}"
                                                CommandParameter="{Binding .}"/>
                                    </Grid>

                                    <!-- No supervisor yet -->
                                    <Button Text="+ Assign Supervisor"
                                            Style="{StaticResource OutlineButtonStyle}"
                                            FontSize="12"
                                            Padding="10,7"
                                            HorizontalOptions="Fill"
                                            IsVisible="{Binding HasSupervisor,
                                                        Converter={StaticResource InvertBool}}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SchedulingViewModel}},
                                                      Path=OpenAssignSupervisorForRowCommand}"
                                            CommandParameter="{Binding .}"/>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- ASSIGN STUDENT MODAL -->
            <Border Style="{StaticResource ModalCardStyle}"
                    IsVisible="{Binding ShowAssignStudent}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="{Binding AssignStudentTitle}"
                           Style="{StaticResource ModalTitleStyle}"/>

                    <Border Style="{StaticResource AlertInfoStyle}"
                            IsVisible="{Binding AssignStudentHasCurrent}">
                        <Label Style="{StaticResource CaptionStyle}"
                               TextColor="{StaticResource InfoDark}">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Currently assigned: "/>
                                    <Span Text="{Binding AssignStudentCurrentName}"
                                          FontFamily="DMSansSemiBold"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </Border>

                    <Label Text="Select student" Style="{StaticResource FormLabelStyle}"/>
                    <Picker ItemsSource="{Binding StudentPickerItems}"
                            SelectedItem="{Binding SelectedStudentForAssign}"
                            Title="— Select —"
                            Style="{StaticResource FormPickerStyle}"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,4,0,0">
                        <Button Grid.Column="0"
                                Text="Cancel"
                                Command="{Binding CancelAssignStudentCommand}"
                                Style="{StaticResource OutlineButtonStyle}"/>
                        <Button Grid.Column="1"
                                Text="Confirm"
                                Command="{Binding ConfirmAssignStudentCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ASSIGN SUPERVISOR MODAL -->
            <Border Style="{StaticResource ModalCardStyle}"
                    IsVisible="{Binding ShowAssignSupervisor}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="{Binding AssignSupervisorTitle}"
                           Style="{StaticResource ModalTitleStyle}"/>

                    <Border Style="{StaticResource AlertInfoStyle}">
                        <Label Text="This assignment is for today only and resets tomorrow."
                               Style="{StaticResource CaptionStyle}"
                               TextColor="{StaticResource InfoDark}"/>
                    </Border>

                    <Label Text="Select supervisor" Style="{StaticResource FormLabelStyle}"/>
                    <Picker ItemsSource="{Binding SupervisorPickerItems}"
                            SelectedItem="{Binding SelectedSupervisorForAssign}"
                            Title="— Select —"
                            Style="{StaticResource FormPickerStyle}"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,4,0,0">
                        <Button Grid.Column="0"
                                Text="Cancel"
                                Command="{Binding CancelAssignSupervisorCommand}"
                                Style="{StaticResource OutlineButtonStyle}"/>
                        <Button Grid.Column="1"
                                Text="Confirm"
                                Command="{Binding ConfirmAssignSupervisorCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>