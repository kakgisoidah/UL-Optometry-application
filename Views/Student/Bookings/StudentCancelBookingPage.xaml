<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                  xmlns:vm="clr-namespace:UL_Optometry.ViewModels.Student"
             
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="UL_Optometry.Views.Student.Bookings.StudentCancelBookingPage"
                 Shell.NavBarIsVisible="False"
              x:DataType="vm:StudentCancelBookingViewModel"
             Style="{StaticResource PageStyle}"
             Title="{Binding Title}">
    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding LoadCommand}"/>
    </ContentPage.Behaviors>


    <ScrollView Style="{StaticResource ScrollStyle}">
        <VerticalStackLayout Spacing="16">
            <Label Text="Cancel Booking" Style="{StaticResource HeadlineStyle}"/>
            <Border Style="{StaticResource AlertSuccessStyle}" IsVisible="{Binding Cancelled}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="✓ Booking cancelled successfully." Style="{StaticResource BodyStyle}" TextColor="{StaticResource SuccessDark}"/>
                    <Button Text="Back to Bookings" Command="{Binding GoToBookingsCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
                </VerticalStackLayout>
            </Border>
            <VerticalStackLayout Spacing="12" IsVisible="{Binding Cancelled, Converter={StaticResource InvertBool}}">
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Reason *" Style="{StaticResource FormLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Picker ItemsSource="{Binding Reasons}" SelectedItem="{Binding SelectedReason}" Title="Select reason" Style="{StaticResource PickerStyle}"/>
                        </Border>
                        <Label Text="Notes (optional)" Style="{StaticResource FormLabelStyle}"/>
                        <Border Style="{StaticResource TextAreaBorderStyle}">
                            <Editor Text="{Binding Notes}" Placeholder="Additional notes..." Style="{StaticResource EditorStyle}" MinimumHeightRequest="80"/>
                        </Border>
                    </VerticalStackLayout>
                </Border>
                <Border Style="{StaticResource AlertDangerStyle}" IsVisible="{Binding HasError}">
                    <Label Text="{Binding ErrorMessage}" Style="{StaticResource BodyStyle}" TextColor="{StaticResource DangerDark}"/>
                </Border>
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource Primary}"/>
                <Button Text="Confirm Cancellation" Command="{Binding ConfirmCancelCommand}" IsEnabled="{Binding IsNotBusy}" Style="{StaticResource DangerButtonStyle}"/>
                <Button Text="← Keep Booking" Command="{Binding BackCommand}" Style="{StaticResource OutlineButtonStyle}"/>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>