<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
              xmlns:vm="clr-namespace:UL_Optometry.ViewModels.Student"
             
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             
             x:Class="UL_Optometry.Views.Student.Profile.StudentProfilePage"
                 Shell.NavBarIsVisible="False"
              x:DataType="vm:StudentProfileViewModel"
             Style="{StaticResource PageStyle}"
             Title="{Binding Title}">
    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding LoadCommand}"/>
    </ContentPage.Behaviors>
    <ScrollView Style="{StaticResource ScrollStyle}">
        <VerticalStackLayout Spacing="16">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource Primary}"/>
            <Border Style="{StaticResource AlertDangerStyle}" IsVisible="{Binding HasError}">
                <Label Text="{Binding ErrorMessage}" Style="{StaticResource BodyStyle}" TextColor="{StaticResource DangerDark}"/>
            </Border>
            <VerticalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,8,0,0">
                <Border Style="{StaticResource AvatarLargeStyle}" HorizontalOptions="Center">
                    <Label Text="{Binding UserProfile.Initials, FallbackValue='?'}"
                           Style="{StaticResource AvatarInitialsStyle}" FontSize="26"/>
                </Border>
                <Label Text="{Binding UserProfile.FullName}" FontFamily="DMSansSemiBold" FontSize="18" HorizontalOptions="Center"/>
                <Border Style="{StaticResource BadgeWarningStyle}" HorizontalOptions="Center">
                    <Label Text="Student" FontFamily="DMSansMedium" FontSize="12" TextColor="{StaticResource WarningDark}"/>
                </Border>
                <Label Text="{Binding UserProfile.Email}" Style="{StaticResource CaptionStyle}" HorizontalOptions="Center"/>
            </VerticalStackLayout>
            <Border Style="{StaticResource AlertSuccessStyle}" IsVisible="{Binding Saved}">
                <Label Text="✓ Profile updated." Style="{StaticResource BodyStyle}" TextColor="{StaticResource SuccessDark}"/>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Edit Profile" FontFamily="DMSansSemiBold" FontSize="14"/>
                    <Label Text="Full Name" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry Text="{Binding FullName}" Placeholder="Full name" Style="{StaticResource EntryStyle}"/>
                    </Border>
                    <Label Text="Phone" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry Text="{Binding Phone}" Placeholder="Phone number" Keyboard="Telephone" Style="{StaticResource EntryStyle}"/>
                    </Border>
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource Primary}"/>
                    <Button Text="Save Changes" Command="{Binding SaveProfileCommand}" IsEnabled="{Binding IsNotBusy}" Style="{StaticResource PrimaryButtonStyle}"/>
                </VerticalStackLayout>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Change Password" FontFamily="DMSansSemiBold" FontSize="14"/>
                    <Border Style="{StaticResource AlertSuccessStyle}" IsVisible="{Binding PasswordChanged}">
                        <Label Text="✓ Password changed successfully." Style="{StaticResource BodyStyle}" TextColor="{StaticResource SuccessDark}"/>
                    </Border>
                    <Label Text="New Password" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry Text="{Binding NewPassword}" Placeholder="Min 8 characters" IsPassword="True" Style="{StaticResource EntryStyle}"/>
                    </Border>
                    <Label Text="Confirm Password" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry Text="{Binding ConfirmPassword}" Placeholder="Confirm new password" IsPassword="True" Style="{StaticResource EntryStyle}"/>
                    </Border>
                    <Button Text="Change Password" Command="{Binding ChangePasswordCommand}" IsEnabled="{Binding IsNotBusy}" Style="{StaticResource OutlineButtonStyle}"/>
                </VerticalStackLayout>
            </Border>
            <Button Text="Log Out" Command="{Binding LogoutCommand}" Style="{StaticResource DangerButtonStyle}" Margin="0,8,0,24"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>