<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:UL_Optometry.ViewModels.Patient"
             xmlns:models="clr-namespace:UL_Optometry.Models"
             x:Class="UL_Optometry.Views.Patient.Encounters.VisitHistoryPage"
                 Shell.NavBarIsVisible="False"
             x:DataType="vm:VisitHistoryViewModel"
             Style="{StaticResource PageStyle}"
             Title="{Binding Title}">
    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding LoadCommand}"/>
    </ContentPage.Behaviors>

    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Grid.Row="0" BackgroundColor="{StaticResource Card}" Padding="16,16,16,12">
            <Label Text="Visit History" Style="{StaticResource TitleStyle}"/>
            <Label Text="Approved clinical encounters (read-only)" Style="{StaticResource MutedLabelStyle}"/>
        </VerticalStackLayout>
        <ScrollView Grid.Row="1" Padding="16,12,16,24">
            <VerticalStackLayout Spacing="12">
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource Primary}" Margin="0,16"/>
                <Border Style="{StaticResource AlertDangerStyle}" IsVisible="{Binding HasError}">
                    <Label Text="{Binding ErrorMessage}" Style="{StaticResource BodyStyle}" TextColor="{StaticResource DangerDark}"/>
                </Border>
                <Label Text="No visit records yet. Your encounters will appear here once approved." Style="{StaticResource MutedLabelStyle}" IsVisible="{Binding IsEmpty}" HorizontalTextAlignment="Center" Margin="0,32"/>
                <CollectionView ItemsSource="{Binding Encounters}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Encounter">
                            <Border Style="{StaticResource QueueItemStyle}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:VisitHistoryViewModel}}, Path=ViewEncounterCommand}" CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                                        <Label Text="{Binding ClinicName}" FontFamily="DMSansSemiBold" FontSize="14"/>
                                        <Label Text="{Binding DateDisplay}" Style="{StaticResource CaptionStyle}"/>
                                        <Label Text="{Binding ExamType}" Style="{StaticResource CaptionStyle}"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="6">
                                        <Border Style="{StaticResource BadgeSuccessStyle}" HorizontalOptions="End">
                                            <Label Text="✓ Approved" FontFamily="DMSansMedium" FontSize="11" TextColor="{StaticResource SuccessDark}"/>
                                        </Border>
                                        <Label Text="View →" Style="{StaticResource CaptionStyle}" TextColor="{StaticResource Accent}" HorizontalOptions="End"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>