<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
              xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:UL_Optometry.ViewModels.Patient"
             x:Class="UL_Optometry.Views.Patient.Profile.PatientProfilePage"
                 Shell.NavBarIsVisible="False"
             x:DataType="vm:PatientProfileViewModel"
             Style="{StaticResource PageStyle}"
             Title="{Binding Title}">
    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding LoadCommand}"/>
    </ContentPage.Behaviors>

    <ScrollView Style="{StaticResource ScrollStyle}">
        <VerticalStackLayout Spacing="0">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}"/>
            <Border Style="{StaticResource AlertDangerStyle}" IsVisible="{Binding HasError}">
                <Label Text="{Binding ErrorMessage}" Style="{StaticResource BodyStyle}"
                       TextColor="{StaticResource DangerDark}"/>
            </Border>

            <VerticalStackLayout Spacing="0" Margin="0,16,0,24" HorizontalOptions="Center">
                <Border Style="{StaticResource AvatarLargeStyle}" HorizontalOptions="Center" Margin="0,0,0,12">
                    <Label Text="{Binding Initials}" Style="{StaticResource AvatarInitialsStyle}" FontSize="26"/>
                </Border>
                <Label Text="{Binding FullName}" FontFamily="DMSansSemiBold" FontSize="18" HorizontalOptions="Center"/>
                <Label Text="{Binding Email}" Style="{StaticResource MutedLabelStyle}" HorizontalOptions="Center" Margin="0,4,0,0"/>
            </VerticalStackLayout>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                <VerticalStackLayout Spacing="0">
                    <Label Text="Account" FontFamily="DMSansSemiBold" FontSize="14" Margin="0,0,0,12"/>
                    <BoxView Style="{StaticResource DividerStyle}" Margin="0"/>
                    <Grid ColumnDefinitions="*,Auto" Padding="0,14">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding EditProfileCommand}"/>
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="Edit Profile" Style="{StaticResource BodyStyle}"/>
                        <Label Grid.Column="1" Text="→" TextColor="{StaticResource Muted}"/>
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" Margin="0"/>
                    <Grid ColumnDefinitions="*,Auto" Padding="0,14">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ViewNotificationsCommand}"/>
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="Notifications" Style="{StaticResource BodyStyle}"/>
                        <Label Grid.Column="1" Text="→" TextColor="{StaticResource Muted}"/>
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" Margin="0"/>
                    <Grid ColumnDefinitions="*,Auto" Padding="0,14">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding HelpCommand}"/>
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="Help &amp; FAQ" Style="{StaticResource BodyStyle}"/>
                        <Label Grid.Column="1" Text="→" TextColor="{StaticResource Muted}"/>
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" Margin="0"/>
                    <Grid ColumnDefinitions="*,Auto" Padding="0,14">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PrivacyPolicyCommand}"/>
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="Privacy Policy" Style="{StaticResource BodyStyle}"/>
                        <Label Grid.Column="1" Text="→" TextColor="{StaticResource Muted}"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>
            <Button Text="Log Out" Command="{Binding LogoutCommand}" Style="{StaticResource DangerButtonStyle}" Margin="0,8,0,32"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>