<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:UL_Optometry.ViewModels.Patient"
             x:Class="UL_Optometry.Views.Patient.Booking.CancelBookingPage"
                 Shell.NavBarIsVisible="False"
             x:DataType="vm:CancelBookingViewModel"
             Style="{StaticResource PageStyle}"
             Title="{Binding Title}">
    
    <ScrollView Style="{StaticResource ScrollStyle}">
        <VerticalStackLayout Spacing="16">
            <Label Text="Cancel Booking" Style="{StaticResource HeadlineStyle}"/>
            <Label Text="Please let us know why you need to cancel." Style="{StaticResource MutedLabelStyle}"/>
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Reason *" Style="{StaticResource FormLabelStyle}"  />
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Picker ItemsSource="{Binding Reasons}" SelectedItem="{Binding SelectedReason}" Title="Select a reason" Style="{StaticResource PickerStyle}" />
                    </Border>
                    <Label Text="Additional Notes (optional)" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource TextAreaBorderStyle}">
                        <Editor Text="{Binding Notes}" Placeholder="Any additional information..." Style="{StaticResource EditorStyle}"/>
                    </Border>
                </VerticalStackLayout>
            </Border>
            <Border Style="{StaticResource AlertDangerStyle}" IsVisible="{Binding HasError}">
                <Label Text="{Binding ErrorMessage}" Style="{StaticResource BodyStyle}" TextColor="{StaticResource DangerDark}"/>
            </Border>
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource Primary}"/>
            <Button Text="Confirm Cancellation" Command="{Binding ConfirmCancelCommand}" IsEnabled="{Binding IsNotBusy}" Style="{StaticResource DangerButtonStyle}"/>
            <Button Text="← Keep My Booking" Command="{Binding BackCommand}" Style="{StaticResource OutlineButtonStyle}"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>