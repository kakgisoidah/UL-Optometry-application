<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UL_Optometry.Views.Auth.ForcePasswordChangePage"
             xmlns:vm="clr-namespace:UL_Optometry.ViewModels.Auth"
             x:DataType="vm:ForcePasswordChangeViewModel"
             Style="{StaticResource PageStyle}"
             Shell.NavBarIsVisible="False"
             Shell.BackButtonBehavior="{x:Null}">
    
    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,32" Spacing="0">

            <!-- Lock icon -->
            <Label Text="🔒" FontSize="52"
                   HorizontalOptions="Center"
                   Margin="0,0,0,16"/>

            <Label Text="Set Your Password"
                   Style="{StaticResource HeadlineStyle}"
                   HorizontalOptions="Center"
                   Margin="0,0,0,8"/>

            <Label Text="Your account was created with a temporary password."
                   Style="{StaticResource MutedLabelStyle}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,8"/>

            <Label Text="You must set a new password before continuing."
                   Style="{StaticResource MutedLabelStyle}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,32"/>

            <!-- Mandatory notice -->
            <Border Style="{StaticResource AlertWarningStyle}" Margin="0,0,0,20">
                <Label Style="{StaticResource BodyStyle}"
                       TextColor="{StaticResource WarningDark}">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="⚠️  "/>
                            <Span Text="You cannot access the portal "
                                  FontFamily="DMSansMedium"/>
                            <Span Text="until this step is completed."/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </Border>

            <!-- Form card -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <VerticalStackLayout Spacing="12">

                    <!-- New password -->
                    <Label Text="New Password  (min 8 characters)"
                           Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Grid ColumnDefinitions="*,44">
                            <Entry Grid.Column="0"
                                   Text="{Binding NewPassword}"
                                   Placeholder="Enter new password"
                                   IsPassword="{Binding IsPasswordVisible,
                                       Converter={StaticResource InvertBool}}"
                                   Style="{StaticResource EntryStyle}"/>
                            <ImageButton Grid.Column="1"
                                         Command="{Binding TogglePasswordVisibilityCommand}"
                                         BackgroundColor="Transparent"
                                         Padding="10"
                                         Source="icon_eye.png"/>
                        </Grid>
                    </Border>

                    <!-- Confirm password -->
                    <Label Text="Confirm New Password"
                           Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Grid ColumnDefinitions="*,44">
                            <Entry Grid.Column="0"
                                   Text="{Binding ConfirmPassword}"
                                   Placeholder="Confirm new password"
                                   IsPassword="{Binding IsConfirmVisible,
                                       Converter={StaticResource InvertBool}}"
                                   Style="{StaticResource EntryStyle}"/>
                            <ImageButton Grid.Column="1"
                                         Command="{Binding ToggleConfirmVisibilityCommand}"
                                         BackgroundColor="Transparent"
                                         Padding="10"
                                         Source="icon_eye.png"/>
                        </Grid>
                    </Border>

                    <!-- Error banner -->
                    <Border Style="{StaticResource AlertDangerStyle}"
                            IsVisible="{Binding HasError}">
                        <Label Text="{Binding ErrorMessage}"
                               Style="{StaticResource BodyStyle}"
                               TextColor="{StaticResource DangerDark}"/>
                    </Border>

                    <!-- Submit button -->
                    <Button Text="Set Password &amp; Continue"
                            Command="{Binding SubmitCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            Style="{StaticResource PrimaryButtonStyle}"/>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="{StaticResource Primary}"/>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>