<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UL_Optometry.Views.Auth.ForgotPasswordPage"
                 Shell.NavBarIsVisible="False"
             xmlns:vm="clr-namespace:UL_Optometry.ViewModels.Auth"
             x:DataType="vm:ForgotPasswordViewModel"
             Style="{StaticResource PageStyle}"
             Title="Reset Password">
    
    <ScrollView>
        <VerticalStackLayout Padding="32,48,32,32" Spacing="0" VerticalOptions="Center">

            <!-- Icon -->
            <Label Text="🔑" FontSize="52"
                   HorizontalOptions="Center"
                   Margin="0,0,0,16"/>

            <Label Text="Forgot Your Password?"
                   Style="{StaticResource HeadlineStyle}"
                   HorizontalOptions="Center"
                   Margin="0,0,0,8"/>

            <Label Text="Enter your email and we'll send a reset link."
                   Style="{StaticResource MutedLabelStyle}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,32"/>

            <!-- ── Success state ── -->
            <VerticalStackLayout IsVisible="{Binding Sent}" Spacing="16">
                <Border Style="{StaticResource AlertSuccessStyle}">
                    <Label Style="{StaticResource BodyStyle}"
                           TextColor="{StaticResource SuccessDark}"
                           HorizontalTextAlignment="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="✓  "/>
                                <Span Text="Reset link sent to " FontFamily="DMSansMedium"/>
                                <Span Text="{Binding Email}" FontFamily="DMSansMedium"/>
                                <Span Text=". Check your inbox."/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </Border>
                <Button Text="Back to Sign In"
                        Command="{Binding BackToLoginCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </VerticalStackLayout>

            <!-- ── Input state ── -->
            <VerticalStackLayout IsVisible="{Binding Sent,
                                     Converter={StaticResource InvertBool}}"
                                 Spacing="0">

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="Email Address" Style="{StaticResource FormLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry Text="{Binding Email}"
                                   Placeholder="your@email.com"
                                   Keyboard="Email"
                                   ReturnType="Done"
                                   ReturnCommand="{Binding SendResetLinkCommand}"
                                   Style="{StaticResource EntryStyle}"/>
                        </Border>

                        <!-- Error banner -->
                        <Border Style="{StaticResource AlertDangerStyle}"
                                IsVisible="{Binding HasError}">
                            <Label Text="{Binding ErrorMessage}"
                                   Style="{StaticResource BodyStyle}"
                                   TextColor="{StaticResource DangerDark}"/>
                        </Border>

                        <Button Text="Send Reset Link"
                                Command="{Binding SendResetLinkCommand}"
                                IsEnabled="{Binding IsNotBusy}"
                                Style="{StaticResource PrimaryButtonStyle}"/>

                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           Color="{StaticResource Primary}"/>

                    </VerticalStackLayout>
                </Border>

                <Button Text="← Back to Sign In"
                        Command="{Binding BackToLoginCommand}"
                        Style="{StaticResource OutlineButtonStyle}"/>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>