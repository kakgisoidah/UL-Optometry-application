<?xml version="1.0" encoding="utf-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ── Primary brand ─────────────────────────────────────────── -->
    <Color x:Key="Primary">#1E3A8A</Color>
    <Color x:Key="PrimaryLight">#1e5099</Color>
    <Color x:Key="PrimaryUltraLight">#EFF6FF</Color>

    <!-- ── Accent (interactive blue) ─────────────────────────────── -->
    <Color x:Key="Accent">#3B82F6</Color>
    <Color x:Key="AccentLight">#DBEAFE</Color>

    <!-- ── Success ────────────────────────────────────────────────── -->
    <Color x:Key="Success">#22C55E</Color>
    <Color x:Key="SuccessLight">#DCFCE7</Color>
    <Color x:Key="SuccessDark">#15803D</Color>

    <!-- ── Warning ────────────────────────────────────────────────── -->
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="WarningLight">#FEF3C7</Color>
    <Color x:Key="WarningDark">#92400E</Color>

    <!-- ── Danger ─────────────────────────────────────────────────── -->
    <Color x:Key="Danger">#EF4444</Color>
    <Color x:Key="DangerLight">#FEE2E2</Color>
    <Color x:Key="DangerDark">#991B1B</Color>

    <!-- ── Info ───────────────────────────────────────────────────── -->
    <Color x:Key="Info">#3B82F6</Color>
    <Color x:Key="InfoLight">#DBEAFE</Color>
    <Color x:Key="InfoDark">#1D4ED8</Color>

    <!-- ── Neutrals ───────────────────────────────────────────────── -->
    <Color x:Key="Dark">#1F2937</Color>
    <Color x:Key="Muted">#6B7280</Color>
    <Color x:Key="Border">#E5E7EB</Color>
    <Color x:Key="Background">#F8FAFC</Color>
    <Color x:Key="Card">#FFFFFF</Color>

    <!-- ── Clinic day colours ─────────────────────────────────────── -->
    <!--  Monday    → Severely Reduced Vision  -->
    <Color x:Key="ClinicMonday">#8B5CF6</Color>
    <!--  Tuesday   → Paediatric               -->
    <Color x:Key="ClinicTuesday">#EC4899</Color>
    <!--  Wednesday → Binocular Vision         -->
    <Color x:Key="ClinicWednesday">#3B82F6</Color>
    <!--  Thursday  → Contact Lens             -->
    <Color x:Key="ClinicThursday">#F59E0B</Color>
    <!--  Friday    → General Consultation     -->
    <Color x:Key="ClinicFriday">#22C55E</Color>

</ResourceDictionary>
